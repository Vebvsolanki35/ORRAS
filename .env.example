# ORRAS Environment Configuration
# Copy this file to .env and fill in your API keys

# Existing keys
NEWSAPI_KEY=your_newsapi_key_here
NASA_FIRMS_KEY=your_nasa_firms_key_here

# These sources are free and require no key:
# GDELT, OpenSky Network, Cloudflare Radar

# Set to "true" to run entirely on mock data (no API calls)
OFFLINE_MODE=false

# NEW: AI Assistant (get free at console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# NEW: AI features toggle (set to "false" to disable AI features)
AI_FEATURES_ENABLED=true
